{
  "expo": {
    "name": "MachineX",
    "slug": "machine-x",
    "scheme": "machinerental",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.machinerental.app"
    },
    "splash": {
  "image": "./assets/images/splash-image.png",
  "resizeMode": "contain"
},
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#F59E0B"
      },
      "package": "com.machinerental.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.INTERNET"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3e84a7e3-4c13-474d-842b-8c9bbc2761fd"
      }
    }
  }
}
